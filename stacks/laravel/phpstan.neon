# Plain PHPStan for the harness-template baseline. Once you've layered a
# real Laravel project on top (`composer create-project laravel/laravel ...`)
# add this line to enable Laravel-aware analysis:
#
# includes:
#     - vendor/larastan/larastan/extension.neon
#
# Larastan needs a bootable bootstrap/app.php, which the template doesn't
# ship — so we keep it disabled here.

parameters:
    level: 8
    paths:
        - app
    excludePaths:
        analyseAndScan:
            - bootstrap/cache/*
            - storage/*
            - vendor/*
            # Pest tests use dynamic helpers (it/expect/arch) that vanilla
            # PHPStan can't model. Pest verifies them at runtime.
            - app/**/*Test.php
            - tests/**/*Test.php
            - checks/**/*Test.php
    treatPhpDocTypesAsCertain: false
