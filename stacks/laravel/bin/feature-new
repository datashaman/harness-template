#!/usr/bin/env bash
# Scaffold a new feature spec file with a placeholder AC table.
# Usage: bin/feature-new <relative-path> <title> [--linked=<ref>]
#
# This is the no-AI fallback. For issues with a body, prefer
# bin/feature-from-issue, which fills in the AC table from the body.
#
# If stdin is not a terminal, its content replaces the Notes placeholder.

set -euo pipefail

REL_PATH=""
TITLE=""
LINKED=""

for arg in "$@"; do
    case "$arg" in
        --linked=*) LINKED="${arg#--linked=}" ;;
        --*) echo "Unknown flag: $arg" >&2; exit 2 ;;
        *)
            if   [[ -z "$REL_PATH" ]]; then REL_PATH="$arg"
            elif [[ -z "$TITLE"    ]]; then TITLE="$arg"
            else echo "Unexpected arg: $arg" >&2; exit 2
            fi
            ;;
    esac
done

if [[ -z "$REL_PATH" || -z "$TITLE" ]]; then
    cat <<EOF >&2
Usage: bin/feature-new <relative-path> <title> [--linked=<ref>]

Example:
  bin/feature-new auth/two-factor "Two-Factor Authentication"
  → creates features/auth/two-factor.md with placeholder AC-1.

Pipe a body in to populate the Notes section:
  gh issue view 42 --json body -q .body | bin/feature-new auth/two-factor "..." --linked=#42
EOF
    exit 2
fi

TARGET="features/${REL_PATH}.md"

if [[ -f "$TARGET" ]]; then
    echo "Already exists: $TARGET" >&2
    exit 1
fi

NOTES="(context, references, edge cases not covered by ACs)"
if [[ ! -t 0 ]]; then
    piped="$(cat)"
    [[ -n "$piped" ]] && NOTES="$piped"
fi

mkdir -p "$(dirname "$TARGET")"

cat > "$TARGET" <<EOF
# ${TITLE}

**Owner:**
**Status:** Draft
**Linked:** ${LINKED}

## Acceptance Criteria

| ID    | Behaviour                          | Level    | Priority |
|-------|------------------------------------|----------|----------|
| AC-1  | (describe the first behaviour)     | feature  | Must     |

## Notes

${NOTES}
EOF

echo "Created $TARGET"
